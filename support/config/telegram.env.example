# =============================================================================
# Aman Support — Environment Variables
# Copy this file to .env and fill in your values
# cp telegram.env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot Configuration
# -----------------------------------------------------------------------------

# Your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram user ID (for escalation notifications)
# Get yours from @userinfobot
OWNER_TELEGRAM_ID=your_telegram_user_id

# Your name — used in escalation messages to customers
OWNER_NAME=your_name_here

# Optional: Telegram group chat ID for a customer support group
# Leave blank if using 1:1 only
SUPPORT_GROUP_ID=

# Optional: Bot username (without @)
BOT_USERNAME=your_bot_username

# -----------------------------------------------------------------------------
# Support Configuration
# -----------------------------------------------------------------------------

# Business name (shown in bot messages)
BUSINESS_NAME=your_business_name

# Timezone for ticket timestamps and scheduled reports
# Examples: Asia/Kuala_Lumpur, Asia/Singapore, UTC
TIMEZONE=Asia/Kuala_Lumpur

# Language preference for bot responses
# Options: en (English), ms (Bahasa Malaysia), auto (match customer language)
DEFAULT_LANGUAGE=auto

# -----------------------------------------------------------------------------
# Escalation Settings
# -----------------------------------------------------------------------------

# Number of frustrated messages before auto-escalation
ESCALATION_ANGER_THRESHOLD=3

# Hours before an unresolved escalation triggers a follow-up reminder
ESCALATION_FOLLOWUP_HOURS=4

# Hours before a standard open ticket triggers a follow-up
TICKET_FOLLOWUP_HOURS=24

# -----------------------------------------------------------------------------
# Report Schedule (cron format)
# Default: daily at 8am and weekly Monday at 8am
# -----------------------------------------------------------------------------

DAILY_REPORT_CRON=0 8 * * *
WEEKLY_REPORT_CRON=0 8 * * 1

# -----------------------------------------------------------------------------
# Memory / Storage
# -----------------------------------------------------------------------------

# Where to store customer history and ticket data
# Options: memory (in-context), file (local JSON), external (provide URL below)
STORAGE_TYPE=memory

# Only required if STORAGE_TYPE=external
STORAGE_URL=
STORAGE_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Notification Preferences
# -----------------------------------------------------------------------------

# Notify owner on new ticket (yes/no)
NOTIFY_NEW_TICKET=yes

# Notify owner on escalation (yes/no)
NOTIFY_ESCALATION=yes

# Notify owner on low CSAT score (1-3 rating)
NOTIFY_LOW_CSAT=yes

# Minimum CSAT to trigger owner notification (1-5)
LOW_CSAT_THRESHOLD=3
