# Aman Muslim — Telegram Bot Environment Configuration
# Copy this file to telegram.env and fill in your actual values.
# NEVER commit telegram.env to version control.

# ============================================
# TELEGRAM BOT
# ============================================

# Your Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Bot username (without @)
TELEGRAM_BOT_USERNAME=AmanMuslimBot

# ============================================
# AMAN MCP INTEGRATION
# ============================================

# MCP server endpoint for this companion
AMAN_MCP_ENDPOINT=https://your-mcp-server.example.com

# API key for MCP server authentication
AMAN_MCP_API_KEY=your_mcp_api_key_here

# Memory namespace for this companion (keeps Muslim memory separate from other Aman companions)
AMAN_MEMORY_NAMESPACE=aman-muslim

# ============================================
# COMPANION IDENTITY
# ============================================

# Display name for the bot
AMAN_BOT_NAME=Aman Muslim

# System prompt file path (relative to project root)
AMAN_IDENTITY_FILE=identity/core.md

# Rules file path
AMAN_RULES_FILE=rules/rules.md

# Workflows file path
AMAN_FLOW_FILE=workflows/flow.md

# ============================================
# ISLAMIC SETTINGS
# ============================================

# Default prayer time calculation method
# Options: JAKIM, ISNA, MWL, EGYPT, KARACHI, TEHRAN, GULF
AMAN_PRAYER_METHOD=JAKIM

# Default language
# Options: ms (Malay), en (English), both (bilingual)
AMAN_DEFAULT_LANGUAGE=both

# Default mazhab for mainstream practice references
# Options: shafii, hanafi, maliki, hanbali
AMAN_DEFAULT_MAZHAB=shafii

# Hadith 40 rotation file
AMAN_HADITH_FILE=content/hadith/hadith-40-nawawi.md

# ============================================
# REMINDER SETTINGS
# ============================================

# Enable prayer time reminders (true/false)
AMAN_PRAYER_REMINDERS=true

# Minutes before prayer to send reminder
AMAN_REMINDER_LEAD_TIME=30

# Enable daily hadith at a set time (true/false)
AMAN_DAILY_HADITH=true

# Time to send daily hadith (24h format, local time)
AMAN_DAILY_HADITH_TIME=08:00

# Enable morning adhkar reminder (true/false)
AMAN_MORNING_ADHKAR_REMINDER=true

# Time to send morning adhkar reminder (after Fajr, in minutes)
AMAN_MORNING_ADHKAR_DELAY=15

# ============================================
# LOGGING
# ============================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log file path (leave empty to log to stdout only)
LOG_FILE=

# ============================================
# OPTIONAL: PRAYER TIME API
# ============================================

# If using an external prayer time API (e.g., Aladhan API)
# Leave empty to use built-in calculation
PRAYER_TIME_API_URL=
PRAYER_TIME_API_KEY=

# ============================================
# NOTES
# ============================================
# - TELEGRAM_BOT_TOKEN: Get from @BotFather on Telegram
# - AMAN_MCP_ENDPOINT: Your deployed MCP server URL
# - AMAN_PRAYER_METHOD: JAKIM is recommended for Malaysian users
# - For questions on setup, see content/guides/getting-started.md
