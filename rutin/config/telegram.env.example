# Aman Rutin — Environment Configuration
#
# 1. Create a Telegram bot via @BotFather on Telegram
#    - Send /newbot and follow the prompts
#    - Copy the bot token below
#
# 2. Choose your LLM provider and add the API key
#
# Tip: Set up one bot for yourself, or a separate one for your parents

# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# LLM Provider — pick ONE:
# Option A: Anthropic (recommended)
ANTHROPIC_API_KEY=your_key_here

# Option B: OpenAI
# OPENAI_API_KEY=your_key_here

# Option C: Ollama (free, local — no key needed)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3
